{
  "name": "universal-media-translator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "desktop": "concurrently \"vite\" \"wait-on http://localhost:5173 && node electron/launcher.cjs\"",
    "build:portable": "vite build && electron-builder && node -e \"const fs=require('fs');fs.copyFileSync('config.json','release/config.json');console.log('config.json copiat in release/');\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "adm-zip": "^0.5.17",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "msedge-tts": "^2.0.5",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.4",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.universal.mediatranslator",
    "productName": "Universal Media Translator",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "portable": {
      "splashImage": null
    },
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/pdf-parse/**",
      "**/*.node"
    ]
  }
}
